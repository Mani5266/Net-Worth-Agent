# ─── Google Gemini AI ──────────────────────────────────────────────────────────
# Required for AI certificate generation and server-side OCR.
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Required for database and file storage.
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Rate Limiting (Upstash Redis) ────────────────────────────────────────────
# Optional for local development (rate limiting is disabled without these).
# Required in production. Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── Gold Price API ───────────────────────────────────────────────────────────
# Optional — the app has a free fallback (api.metals.live).
# Only needed if you want a premium API for higher rate limits.
METALS_API_KEY=optional

# ─── MSG91 OTP (Phone Login) ─────────────────────────────────────────────────
# Required for phone-based OTP login. Get from MSG91 dashboard.
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_TEMPLATE_ID=your_msg91_template_id_here

# ─── Phone Auth Secret ────────────────────────────────────────────────────────
# Dedicated secret for deriving internal Supabase passwords for phone users.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_AUTH_SECRET=your_random_64_char_hex_here
